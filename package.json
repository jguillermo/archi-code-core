{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @code-core/common && npm run build -w @code-core/test && npm run build -w @code-core/domain && npm run build -w @code-core/criteria && npm run build -w @code-core/ephemeradb && npm run build -w @code-core/crypto-tools",
    "test": "npm run test -ws --if-present",
    "coverage": "npm run coverage -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "lint:fix": "npm run lint:fix -ws --if-present",
    "format": "npm run format -ws --if-present",
    "format:fix": "npm run format:fix -ws --if-present",
    "fix": "npm run lint:fix && npm run format:fix",
    "editorconfig:check": "editorconfig-checker --exclude node_modules --exclude dist --exclude '.git'",
    "prepare": "husky",
    "clean": "rm -rf packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.13",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "bcrypt": "^6.0.0",
    "editorconfig-checker": "^6.1.1",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "expect-type": "1.3.0",
    "fast-uri": "^3.1.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers-sumo": "^0.8.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
